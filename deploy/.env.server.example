# ===== MadMen API — .env de PRODUCTION (serveur) =====
# Copier en .env à la racine du repo cloné, puis remplir les CHANGER_*.
# Ce fichier sert À LA FOIS à l'app PHP (monté dans le conteneur) ET au conteneur MySQL.
# NE JAMAIS committer (déjà gitignored).

# --- Application ---
APP_ENV=production
APP_DEBUG=false
# Générer des secrets NEUFS sur le serveur :
#   openssl rand -hex 32    -> APP_KEY (signe aussi les JWT)
#   openssl rand -hex 24    -> API_KEY
APP_KEY=CHANGER_app_key_64_hex
API_KEY=CHANGER_api_key_48_hex
AUTH_ENABLED=true
BRUTE_FORCE_ENABLED=true
BIO_SIMULATION=false

# Origine(s) autorisée(s) pour le dashboard/front. '*' pour démarrer, à restreindre ensuite.
CORS_ORIGIN=*

# --- Base de données (conteneur 'db' du compose) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=madmen
DB_USER=madmen
DB_PASS=CHANGER_mot_de_passe_db
# Utilisés UNIQUEMENT par le conteneur MySQL :
DB_ROOT_PASSWORD=CHANGER_mot_de_passe_root
