# Copier ce fichier en .env et adapter les valeurs
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=madmen
DB_USER=root
DB_PASS=

APP_ENV=local
APP_DEBUG=false
# Clé de chiffrement des gabarits biométriques.
# IMPORTANT : RÉGÉNÉRER une valeur unique en prod (ex. base64:$(openssl rand -base64 32)).
# Changer APP_KEY rend illisibles les gabarits déjà chiffrés (il faut ré-enrôler).
APP_KEY=changez-moi-en-production

# Authentification de l'API (clé statique Bearer).
# AUTH_ENABLED=true => toute route hors liste blanche exige Authorization: Bearer <API_KEY>.
AUTH_ENABLED=false
API_KEY=changez-moi-en-production

# CORS : origine autorisée du front. '*' pour la démo ; restreindre en prod (ex. http://127.0.0.1:5173).
CORS_ORIGIN=*

# Biométrie — lecteur d'empreintes
BIO_DEVICE=zkteco                    # zkteco | digitalpersona | secugen
BIO_BRIDGE_URL=http://127.0.0.1:8080 # service local installé sur le poste
BIO_SAMPLES=3                        # captures pour enrôler un doigt
BIO_THRESHOLD=55                     # seuil de correspondance (0-100)
BIO_TEMPLATE_FORMAT=ansi             # ansi | iso | zk
BIO_SIMULATION=true                  # false quand le vrai lecteur est branché

# Pointeuse K40 (terminal de pointage)
K40_ENABLED=false                    # true quand le K40 est branché et configuré
K40_IP=192.168.1.201                 # IP fixe du terminal sur le LAN
K40_PORT=4370                        # port du protocole ZKTeco
K40_PASSWORD=0                       # clé de comm (0 = aucune)
K40_HEURE_LIMITE=08:15               # au-delà = retard
K40_MODE=pull                        # pull (API->K40 sur LAN) | push (K40->API via /iclock) | both
