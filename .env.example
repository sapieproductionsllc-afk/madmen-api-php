# Copier ce fichier en .env et adapter les valeurs
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=madmen
DB_USER=root
DB_PASS=

# Environnement. 'production' par défaut (sûr). Mettre 'local' UNIQUEMENT pour le
# développement sur votre poste : c'est le SEUL cas où l'auth peut être désactivée.
APP_ENV=production
APP_DEBUG=false
# Clé de chiffrement des gabarits biométriques.
# IMPORTANT : RÉGÉNÉRER une valeur unique en prod (ex. base64:$(openssl rand -base64 32)).
# Changer APP_KEY rend illisibles les gabarits déjà chiffrés (il faut ré-enrôler).
APP_KEY=changez-moi-en-production

# Fuseau horaire de l'application. Aligne date() (PHP) et NOW()/CURDATE() (MySQL).
# Bureau MADMEN = UTC+1 (Afrique centrale ouest, sans DST). NE PAS laisser en UTC,
# sinon la fenêtre de pause déjeuner (présence "En pause"/"Parti") est décalée.
APP_TIMEZONE=Africa/Lagos

# Authentification de l'API (clé statique Bearer + JWT par rôle).
# FAIL-CLOSED : l'auth est ACTIVE par défaut. On ne peut la désactiver (AUTH_ENABLED=false)
# QUE si APP_ENV=local. En production, AUTH_ENABLED=false est ignoré (l'auth reste active).
AUTH_ENABLED=true
API_KEY=changez-moi-en-production
# Clés multiples (séparées par des virgules) : une clé par agent/poste/rôle.
# Vide = on s'appuie sur API_KEY seule. API_KEY et API_KEYS sont cumulatives.
API_KEYS=

# CORS : origine EXACTE du dashboard. '*' est REFUSÉ au démarrage en production.
# Renseigner l'URL réelle (ex. https://app.exemple.com) ; en dev local : http://127.0.0.1:5173.
CORS_ORIGIN=http://127.0.0.1:5173

# Biométrie — lecteur d'empreintes
BIO_DEVICE=zkteco                    # zkteco | digitalpersona | secugen
BIO_BRIDGE_URL=http://127.0.0.1:8080 # service local installé sur le poste
BIO_SAMPLES=3                        # captures pour enrôler un doigt
BIO_THRESHOLD=55                     # seuil de correspondance (0-100)
BIO_TEMPLATE_FORMAT=ansi             # ansi | iso | zk
BIO_SIMULATION=true                  # false quand le vrai lecteur est branché

# Pointeuse K40 (terminal de pointage)
K40_ENABLED=false                    # true quand le K40 est branché et configuré
K40_IP=192.168.1.201                 # IP fixe du terminal sur le LAN
K40_PORT=4370                        # port du protocole ZKTeco
K40_PASSWORD=0                       # clé de comm (0 = aucune)
K40_HEURE_LIMITE=08:15               # au-delà = retard
K40_MODE=pull                        # pull (API->K40 sur LAN) | push (K40->API via /iclock) | both
# Liste blanche des SN autorisés en mode Push ; vide = accepte tout (dev) ; à renseigner en prod.
K40_PUSH_SN=                         # ex. K40_PUSH_SN=ABC123,DEF456

# Règles de présence
PRESENCE_DEBUT=08:30                  # début de présence ; arrivée après = retard
PRESENCE_FIN=18:00                    # fin de présence ; après = heures supplémentaires
DEJEUNER_DEBUT=12:30                  # début pause déjeuner (exclue du temps de présence)
DEJEUNER_FIN=14:00                    # fin pause déjeuner

BRUTE_FORCE_ENABLED=true
# --- Relais cloud (bureau -> cloud) : ACTIF uniquement sur la passerelle locale ---
RELAIS_ENABLED=false
RELAIS_CLOUD_URL=https://api-madmen.ssmanager.uk
GATEWAY_TOKEN=changez-moi
RELAIS_INTERVAL_SEC=0
